# ============================================================
# ASTRA AI — BACKEND ENVIRONMENT CONFIGURATION
# ============================================================
# HOW TO USE:
#   1. Copy this file and rename the copy to .env
#   2. Replace every value that says YOUR_XXXX_HERE with your real key
#   3. NEVER commit the .env file to git — it is already in .gitignore
#   4. If a teammate needs keys, share via WhatsApp ONLY, never via code
# ============================================================


# ────────────────────────────────────────────────────────────
# SECTION 1 — HUGGING FACE
# Get from: huggingface.co → Settings → Access Tokens → New Token (read)
# Model used: openai/clip-vit-base-patch32
# FREE TIER LIMITS:
#   - ~1000 requests/hour on Inference API
#   - If you hit HTTP 429, the code waits 60 sec and retries automatically
#   - To stay safe: code sleeps 1.2 sec between every frame request
#   - A 30-sec video = ~15 frames = 15 API calls = well within limit
# ────────────────────────────────────────────────────────────

HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_TOKEN_HERE


# ────────────────────────────────────────────────────────────
# SECTION 2 — GOOGLE GEMINI
# Get from: aistudio.google.com → Get API Key → Create API key
# Model used: gemini-1.5-flash (fastest + cheapest on free tier)
# FREE TIER LIMITS:
#   - 15 requests per minute (RPM)
#   - 1,000,000 tokens per minute (TPM)  ← never hit this in demo
#   - 1,500 requests per day
#   - Gemini is only called when similarity > 0.82, so in demo
#     you will make maybe 2-5 Gemini calls total — well within limit
# ────────────────────────────────────────────────────────────

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE


# ────────────────────────────────────────────────────────────
# SECTION 3 — FIREBASE ADMIN SDK
# Get from: Firebase Console → Project Settings → Service Accounts
#           → Generate new private key → saves as JSON file
# Place the downloaded JSON file inside astra_backend/ folder
# The path below assumes you named it firebase_credentials.json
# NEVER rename or move this file without updating this path
# ────────────────────────────────────────────────────────────

FIREBASE_CREDENTIALS_PATH=./firebase_credentials.json


# ────────────────────────────────────────────────────────────
# SECTION 4 — FIREBASE PROJECT CONFIG
# Get from: Firebase Console → Project Settings → General
#           → Your apps → Web app → SDK setup and configuration
# These are NOT secret (they are used in Flutter frontend too)
# but we keep them here for easy server-side reference
# ────────────────────────────────────────────────────────────

FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
FIREBASE_WEB_API_KEY=YOUR_FIREBASE_WEB_API_KEY_HERE


# ────────────────────────────────────────────────────────────
# SECTION 5 — FASTAPI SERVER CONFIG
# These control how the local Python server runs
# Do not change PORT unless 8000 is already taken on your machine
# ────────────────────────────────────────────────────────────

SERVER_PORT=8000

# Set to "development" during hackathon, "production" never (it's a demo)
ENVIRONMENT=development

# CORS origin — asterisk means allow all origins (fine for demo)
# In production this would be your specific Flutter web domain
CORS_ORIGINS=*


# ────────────────────────────────────────────────────────────
# SECTION 6 — NGROK TUNNEL
# Get from: ngrok.com → Your Authtoken (dashboard)
# The ngrok URL changes every restart — update api_config.dart in Flutter
# ────────────────────────────────────────────────────────────

NGROK_AUTHTOKEN=YOUR_NGROK_AUTHTOKEN_HERE

# Leave this blank — filled in manually at runtime when ngrok starts
NGROK_PUBLIC_URL=


# ────────────────────────────────────────────────────────────
# SECTION 7 — AI PIPELINE TUNING
# Only change these if detections are wrong during testing
# ────────────────────────────────────────────────────────────

# Cosine similarity threshold to trigger Gemini intent check
# Lower (e.g. 0.70) = more detections but more false positives
# Higher (e.g. 0.90) = fewer but higher confidence detections
SIMILARITY_THRESHOLD=0.82

# 1 frame every N seconds — DO NOT go below 2 (memory crash + rate limit)
FRAME_EXTRACTION_INTERVAL=2

# Hard cap on frames per video — prevents memory exhaustion on long videos
MAX_FRAMES_PER_VIDEO=30

# DO NOT CHANGE — 224x224 is the required input size for clip-vit-base-patch32
FRAME_SIZE_PX=224

# Sleep between HuggingFace API calls — DO NOT set below 1.0
HUGGINGFACE_SLEEP_INTERVAL=1.2

# Wait time before retrying after a 429 rate limit error
HUGGINGFACE_RETRY_WAIT_SECONDS=60

# How often the scanner checks mock_internet_feed for new files
# Lower to 20 for a more impressive live demo — never below 15
SCANNER_POLL_INTERVAL=45


# ────────────────────────────────────────────────────────────
# SECTION 8 — FILE PATHS
# Relative to astra_backend/ — only change if you rename folders
# ────────────────────────────────────────────────────────────

MOCK_FEED_DIR=./mock_internet_feed
TEMP_DIR=./temp
FRAMES_SUBDIR=./temp/frames
STORAGE_VAULT_FOLDER=vault
STORAGE_TEMP_FOLDER=temp


# ────────────────────────────────────────────────────────────
# SECTION 9 — FIRESTORE COLLECTION NAMES
# Must exactly match what you created in Firebase Console
# If you change these, update the collection name strings in Flutter too
# ────────────────────────────────────────────────────────────

FIRESTORE_VAULTED_ASSETS_COLLECTION=vaulted_assets
FIRESTORE_THREAT_ALERTS_COLLECTION=threat_alerts
FIRESTORE_CONTAGION_NODES_COLLECTION=contagion_nodes
FIRESTORE_SYSTEM_STATE_COLLECTION=system_state
FIRESTORE_PROCESSING_STATUS_DOC=processing_status


# ────────────────────────────────────────────────────────────
# SECTION 10 — WATERMARK / CRYPTOGRAPHY
# ────────────────────────────────────────────────────────────

# Frame index to embed watermark into — DO NOT CHANGE
# Decrypt endpoint also extracts frame 0, must match
WATERMARK_FRAME_INDEX=0

# SECURITY NOTE: Fernet key is stored in Firestore for demo only.
# In production this MUST go into Google Cloud Secret Manager.
WATERMARK_KEY_STORAGE=firestore


# ────────────────────────────────────────────────────────────
# END OF FILE
# ────────────────────────────────────────────────────────────